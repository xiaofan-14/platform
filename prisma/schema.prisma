// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  email       String    @unique
  password    String
  createdAt   DateTime  @default(now())
  
  // 软删除相关
  deletedAt   DateTime?
  
  // 1. 标量字段：存储执行删除操作的人的 ID
  deletedById Int?
  
  // 2. 关联字段：指向 User 对象本身
  // 注意：我们通过 name 给这个关系命名，以便 Prisma 识别
  deletedBy   User?     @relation("UserDeletions", fields: [deletedById], references: [id])
  
  // 3. 反向关联：由于是自引用，需要定义一个人删除了哪些用户
  deletedUsers User[]    @relation("UserDeletions")

  @@map("users")
}

// 设备状态枚举
enum DeviceStatus {
  online
  offline
}

// 设备模型
model Device {
  id        Int          @id @default(autoincrement())
  name      String       @unique // 设备唯一名称
  cpuUsage  Float        @default(0) // CPU 占用率 (0-100)
  status    DeviceStatus @default(offline) // 在线状态
  createdAt DateTime     @default(now()) // 创建时间
  updatedAt DateTime     @updatedAt // 更新时间

  @@map("devices")
}
