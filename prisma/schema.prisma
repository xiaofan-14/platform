// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  password     String
  createdAt    DateTime  @default(now())
  
  // 软删除
  deletedAt    DateTime?
  deletedById  Int?
  deletedBy    User?     @relation("UserDeletions", fields: [deletedById], references: [id])
  deletedUsers User[]    @relation("UserDeletions")

  // 一个用户可以有多个活跃 Session（多端登录）
  sessions     Session[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid()) // 这里的 ID 就是你要存入 Cookie 的随机 sess_id
  sessionToken String   @unique             // 也可以作为索引字段，双重保险
  userId       Int
  expires      DateTime                     // 强过期的硬指标

  // 扩展信息：用于安全审计
  ipAddress    String?
  userAgent    String?
  
  // 关联用户
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sessions")
  @@index([userId]) // 方便查询某个用户的所有设备
}

// 设备状态枚举
enum DeviceStatus {
  online
  offline
}

// 设备模型
model Device {
  id        Int          @id @default(autoincrement())
  name      String       @unique // 设备唯一名称
  cpuUsage  Float        @default(0) // CPU 占用率 (0-100)
  status    DeviceStatus @default(offline) // 在线状态
  createdAt DateTime     @default(now()) // 创建时间
  updatedAt DateTime     @updatedAt // 更新时间

  @@map("devices")
}
